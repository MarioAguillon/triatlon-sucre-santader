# ============================================================
# TRIATLÓN SUCRE SIN LÍMITES 2.0 — Variables de Entorno (EJEMPLO)
# ============================================================
# Copia este archivo como .env y configura tus valores reales.
# NUNCA subas el archivo .env real al repositorio.

# Servidor
PORT=3000
NODE_ENV=development

# ==========================================
# VARIABLES LOCALES (XAMPP/MySQL) - Comentadas
# ==========================================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=triatlon_sucre
# DB_SSL=false

# ==========================================
# VARIABLES TiDB CLOUD (Producción)
# ==========================================
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=TU_USUARIO_TIDB
DB_PASSWORD=TU_PASSWORD_TIDB
DB_NAME=test
DB_SSL=true

# JWT — Clave secreta (generar una nueva y segura para producción)
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_ALEATORIA
JWT_EXPIRES_IN=8h

# CORS — Orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:4200

# Google reCAPTCHA v2 — Obtener claves en https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=TU_SECRET_KEY_DE_RECAPTCHA

# Configuración de Correo SMTP (Ej: Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=triatlonsucresantander@gmail.com
SMTP_PASS=TU_CONTRASEÑA_DE_APLICACION
