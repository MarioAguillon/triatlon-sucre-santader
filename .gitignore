# ============================================================
# .gitignore — Triatlón Sucre Sin Límites 2.0
# ============================================================

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ── Angular (frontend) ──────────────────────────────────────
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/.angular/cache

# ── Environment variables ────────────────────────────────────
.env
.env.local
.env.production

# ── IDEs ─────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
*.log

# ── Coverage / Testing ───────────────────────────────────────
coverage/
__screenshots__/
